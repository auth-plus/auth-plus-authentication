{
  "name": "auth-service",
  "version": "1.0.0",
  "description": "Backend Auth Service",
  "scripts": {
    "dev": "nodemon",
    "start": "node --require './build/src/presentation/tracing.js' build/src/presentation/http/server.js",
    "lint": "eslint . --fix && prettier . --write",
    "lint:check": "eslint . && prettier . --check",
    "build": "tsc --project tsconfig.json",
    "build:check": "npm run build -- --noEmit",
    "test": "env NODE_ENV=test jest --detectOpenHandles --runInBand --forceExit",
    "stryker": "npx stryker run --logLevel trace"
  },
  "keywords": [
    "express",
    "auth"
  ],
  "main": "build/presentation/http/server.js",
  "author": "Andrew Hanasiro",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/AndrewHanasiro/tournament/issues"
  },
  "homepage": "https://github.com/AndrewHanasiro/tournament#readme",
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-zipkin": "2.6.1",
    "@opentelemetry/instrumentation": "0.214.0",
    "@opentelemetry/instrumentation-winston": "^0.58.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "bcrypt": "6.0.0",
    "body-parser": "2.2.2",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "helmet": "8.1.0",
    "joi": "18.1.2",
    "jsonwebtoken": "9.0.3",
    "kafkajs": "2.2.4",
    "knex": "3.2.9",
    "otpauth": "^9.5.0",
    "pg": "8.20.0",
    "prom-client": "15.1.3",
    "redis": "5.11.0",
    "swagger-ui-express": "5.0.1",
    "winston": "3.19.0",
    "zxcvbn": "4.4.2"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "^9.39.4",
    "@eslint/json": "^1.2.0",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/jest-runner": "9.6.1",
    "@testcontainers/kafka": "11.14.0",
    "@testcontainers/postgresql": "11.14.0",
    "@testcontainers/redis": "11.14.0",
    "@types/bcrypt": "6.0.0",
    "@types/chai": "5.2.3",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "24.10.2",
    "@types/supertest": "7.2.0",
    "@types/swagger-ui-express": "4.1.8",
    "@types/zxcvbn": "4.4.5",
    "@typescript-eslint/parser": "8.58.2",
    "casual": "1.6.2",
    "chai": "6.2.2",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sonarjs": "4.0.2",
    "globals": "^17.5.0",
    "husky": "9.1.7",
    "jest": "^30.3.0",
    "nock": "15.0.0",
    "nodemon": "3.1.14",
    "nyc": "18.0.0",
    "prettier": "3.8.2",
    "supertest": "7.2.2",
    "ts-jest": "^29.4.9",
    "ts-mockito": "2.6.1",
    "ts-node": "10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  }
}
